NODE_ENV=development
PORT=4000

# FHIR Server (HAPI FHIR running via Docker)
FHIR_BASE_URL=http://localhost:8080/fhir
FHIR_SERVICE_TOKEN=dev-service-token

# CQL Translation Service
CQL_SERVICE_URL=http://localhost:8090

# Auth (Keycloak SMART on FHIR)
JWKS_URI=http://localhost:8180/realms/bisharod/protocol/openid-connect/certs
JWT_AUDIENCE=bisharod-api

# Database
DATABASE_URL=postgresql://bisharod:bisharod@localhost:5432/bisharod

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:5173
